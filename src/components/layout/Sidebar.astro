---
import { getCollection } from 'astro:content';

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;

const allChapters = await getCollection('chapters');
const chapters = allChapters
  .filter((ch) => !ch.data.draft)
  .sort((a, b) => a.data.chapter - b.data.chapter);
---

<aside id="sidebar" class="sidebar" aria-label="章节导航">
  <!-- Logo / Site Title -->
  <div class="sidebar-header">
    <a href="/" class="logo-link">
      <span class="logo-icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10" />
          <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20" />
          <path d="M2 12h20" />
        </svg>
      </span>
      <span class="logo-text">Pi Agent 教程</span>
    </a>
  </div>

  <!-- Chapter Nav -->
  <nav class="chapter-nav">
    <p class="nav-label">章节目录</p>
    <ul class="chapter-list">
      {chapters.map((chapter, i) => {
        const isActive = currentSlug === chapter.id;
        const isAppendix = chapter.data.chapter >= 90;
        const prevChapter = i > 0 ? chapters[i - 1] : null;
        const showAppendixLabel = isAppendix && (!prevChapter || prevChapter.data.chapter < 90);
        return (
          <>
            {showAppendixLabel && (
              <li class="nav-divider">
                <span class="nav-divider-label">附录</span>
              </li>
            )}
            <li>
              <a
                href={`/${chapter.id}`}
                class:list={['chapter-link', { active: isActive }]}
                aria-current={isActive ? 'page' : undefined}
              >
                <span class="chapter-number">
                  {isAppendix
                    ? String.fromCharCode(65 + chapter.data.chapter - 90)
                    : String(chapter.data.chapter).padStart(2, '0')}
                </span>
                <span class="chapter-title">{chapter.data.title}</span>
              </a>
            </li>
          </>
        );
      })}
    </ul>
  </nav>

  <!-- Footer Link -->
  <div class="sidebar-footer">
    <a href="https://github.com/HelloiOS2014/pi_rsearch" target="_blank" rel="noopener noreferrer" class="github-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
      </svg>
      <span>pi-mono</span>
    </a>
  </div>
</aside>

<!-- Mobile toggle button -->
<button
  id="sidebar-toggle"
  class="sidebar-toggle"
  aria-label="打开导航菜单"
  aria-expanded="false"
>
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
    <line x1="3" y1="6" x2="21" y2="6" />
    <line x1="3" y1="12" x2="21" y2="12" />
    <line x1="3" y1="18" x2="21" y2="18" />
  </svg>
</button>

<!-- Mobile overlay -->
<div id="sidebar-overlay" class="sidebar-overlay"></div>

<script>
  function initSidebar() {
    const toggle = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');

    if (!toggle || !sidebar || !overlay) return;

    function open() {
      sidebar.classList.add('is-open');
      overlay.classList.add('is-visible');
      toggle.setAttribute('aria-expanded', 'true');
    }

    function close() {
      sidebar.classList.remove('is-open');
      overlay.classList.remove('is-visible');
      toggle.setAttribute('aria-expanded', 'false');
    }

    toggle.addEventListener('click', () => {
      const isOpen = sidebar.classList.contains('is-open');
      isOpen ? close() : open();
    });

    overlay.addEventListener('click', close);
  }
  initSidebar();
  document.addEventListener('astro:after-swap', initSidebar);
</script>

<style>
  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 260px;
    background: var(--bg-sidebar);
    border-right: 1px solid var(--border-subtle);
    display: flex;
    flex-direction: column;
    z-index: 40;
    overflow-y: auto;
    transition: transform 0.25s ease;
  }

  .sidebar-header {
    padding: 1.5rem 1.25rem 1rem;
    border-bottom: 1px solid var(--border-subtle);
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    color: var(--text-primary);
    transition: color 0.15s ease;
  }

  .logo-link:hover {
    color: var(--accent);
  }

  .logo-icon {
    color: var(--accent);
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .logo-text {
    font-weight: 600;
    font-size: 0.9375rem;
    letter-spacing: -0.01em;
  }

  .chapter-nav {
    flex: 1;
    padding: 1rem 0;
    overflow-y: auto;
  }

  .nav-label {
    padding: 0 1.25rem;
    margin-bottom: 0.5rem;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }

  .chapter-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .chapter-link {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    padding: 0.5rem 1.25rem;
    text-decoration: none;
    color: var(--text-secondary);
    font-size: 0.875rem;
    line-height: 1.4;
    border-left: 2px solid transparent;
    transition: all 0.15s ease;
  }

  .chapter-link:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.03);
  }

  .chapter-link.active {
    color: var(--accent);
    border-left-color: var(--accent);
    background: rgba(217, 119, 87, 0.06);
  }

  .chapter-number {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--text-muted);
    flex-shrink: 0;
    width: 1.5em;
  }

  .chapter-link.active .chapter-number {
    color: var(--accent-deep);
  }

  .nav-divider {
    padding: 0.75rem 1.25rem 0.25rem;
    margin-top: 0.25rem;
    border-top: 1px solid var(--border-subtle);
  }

  .nav-divider-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }

  .chapter-title {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .sidebar-footer {
    padding: 1rem 1.25rem;
    border-top: 1px solid var(--border-subtle);
  }

  .github-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .github-link:hover {
    color: var(--text-primary);
  }

  /* ─── Mobile Toggle ─── */
  .sidebar-toggle {
    display: none;
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 50;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text-primary);
    cursor: pointer;
    align-items: center;
    justify-content: center;
  }

  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 35;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .sidebar-overlay.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  @media (max-width: 1023px) {
    .sidebar {
      transform: translateX(-100%);
    }

    .sidebar.is-open {
      transform: translateX(0);
      box-shadow: 4px 0 24px rgba(0, 0, 0, 0.4);
    }

    .sidebar-toggle {
      display: flex;
    }

    .sidebar-overlay {
      display: block;
      pointer-events: none;
    }
  }
</style>
